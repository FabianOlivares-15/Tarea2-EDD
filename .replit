args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc tdas/*.c tarea2.c -Wno-unused-result -o tarea2 && ./tarea2"

[workflows.workflow.metadata]
